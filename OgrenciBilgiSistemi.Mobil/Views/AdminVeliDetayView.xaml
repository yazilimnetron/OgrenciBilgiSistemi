<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminVeliDetayView"
             Title="Veli Detayı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#E67E22" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="#E67E22" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Veli Detayı" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15,15" Spacing="12">

                <!-- Profil kartı -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="White" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="AdSoyadLabel" Text="" FontSize="17" FontFamily="OpenSansSemibold" TextColor="#2C3E50" />
                        <Label x:Name="YakinlikLabel" Text="" FontSize="13" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Border>

                <!-- İletişim -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="White" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="İletişim" FontSize="14" FontFamily="OpenSansSemibold" TextColor="#E67E22" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Telefon" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="TelefonLabel" Text="-" FontSize="14" TextColor="#2C3E50" FontFamily="OpenSansSemibold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTelefonTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="E-Posta" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="EmailLabel" Text="-" FontSize="14" TextColor="#2C3E50" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Adres" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="AdresLabel" Text="-" FontSize="14" TextColor="#2C3E50" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- İş bilgileri -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="White" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="İş Bilgileri" FontSize="14" FontFamily="OpenSansSemibold" TextColor="#E67E22" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Meslek" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="MeslekLabel" Text="-" FontSize="14" TextColor="#2C3E50" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="İş Yeri" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="IsYeriLabel" Text="-" FontSize="14" TextColor="#2C3E50" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Çocuklar -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="White" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="CocuklarBaslik" Text="Çocuklar" FontSize="14" FontFamily="OpenSansSemibold" TextColor="#E67E22" />
                        <CollectionView x:Name="CocukCollection" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,10" BackgroundColor="#F7F9FB">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCocukSecildi" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="10">
                                            <BoxView Grid.Column="0" BackgroundColor="#1F4E79" WidthRequest="4"
                                                     VerticalOptions="Fill" HorizontalOptions="Center">
                                                <BoxView.Clip>
                                                    <RoundRectangleGeometry CornerRadius="2" Rect="0,0,4,40" />
                                                </BoxView.Clip>
                                            </BoxView>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding OgrenciAdSoyad}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="#2C3E50" />
                                                <Label Text="{Binding BirimAd}" FontSize="11" TextColor="#7F8C8D" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding OgrenciNo, StringFormat='No: {0}'}"
                                                   FontSize="11" TextColor="#95A5A6" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Bu veliye bağlı aktif öğrenci yok." FontSize="12" TextColor="#95A5A6" HorizontalOptions="Center" Padding="0,10" />
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="DurumYazisi" Text="" FontSize="13" TextColor="#E74C3C" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
