<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminOgretmenDetayView"
             Title="Öğretmen Detayı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#16A085" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="#16A085" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Öğretmen Detayı" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15,15" Spacing="12">

                <!-- Profil kartı -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="White" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="80, *" ColumnSpacing="14">
                        <Border Grid.Column="0" WidthRequest="80" HeightRequest="80"
                                StrokeShape="RoundRectangle 40" StrokeThickness="2" Stroke="#16A085"
                                BackgroundColor="#F0F2F5">
                            <Image x:Name="GorselImage" Aspect="AspectFill" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label x:Name="AdSoyadLabel" Text="" FontSize="17" FontFamily="OpenSansSemibold" TextColor="#2C3E50" />
                            <Label x:Name="BirimLabel" Text="" FontSize="13" TextColor="#7F8C8D" />
                            <Border x:Name="DurumRozet" StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                    BackgroundColor="#27AE60" Padding="8,3" HorizontalOptions="Start">
                                <Label x:Name="DurumLabel" Text="Aktif" FontSize="11" TextColor="White" FontFamily="OpenSansSemibold" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- İletişim -->
                <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="White" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="İletişim" FontSize="14" FontFamily="OpenSansSemibold" TextColor="#16A085" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Telefon" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="TelefonLabel" Text="-" FontSize="14" TextColor="#2C3E50" FontFamily="OpenSansSemibold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTelefonTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="E-Posta" FontSize="11" TextColor="#95A5A6" />
                            <Label x:Name="EmailLabel" Text="-" FontSize="14" TextColor="#2C3E50" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="DurumYazisi" Text="" FontSize="13" TextColor="#E74C3C" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
