<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.SinifListeView"
             Title="Sınıf Listesi"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F2F2">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="#1ABC9C"
                VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="#1ABC9C" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>

            <Grid>
                <views:AnaBaslikView x:Name="MyHeader"
                                      ShowBack="False"
                                      ShowProfile="True" />

                <VerticalStackLayout Spacing="2"
                                     VerticalOptions="End"
                                     Margin="20,0,20,35">
                    <Label x:Name="WelcomeLabel"
                           Text="Merhaba"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                    <Label Text="Sınıf Seçiniz"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Border Margin="15,-28,15,0"
                    HeightRequest="55"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="0"
                    BackgroundColor="White">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.08" />
                </Border.Shadow>
                <Grid ColumnDefinitions="55, *">
                    <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" HorizontalOptions="Center" FontSize="18" TextColor="#95A5A6" />
                    <Entry Grid.Column="1" x:Name="SearchBar" Placeholder="Hangi sınıfı arıyorsun?" PlaceholderColor="#95A5A6"
                           TextColor="#2C3E50" FontSize="15" VerticalOptions="Center" TextChanged="OnSearchBarTextChanged" />
                </Grid>
            </Border>

            <!-- Randevu, Müsaitlik ve Bildirim butonları -->
            <Grid ColumnDefinitions="*, *, *" Margin="15,0,15,5" ColumnSpacing="8">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="#2980B9" Padding="8,6" HeightRequest="36">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRandevularTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="Randevular" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="#8E44AD" Padding="8,6" HeightRequest="36">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMusaitlikTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="Müsaitlik" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Grid Grid.Column="2">
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            BackgroundColor="#E67E22" Padding="8,6" HeightRequest="36">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBildirimlerTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="Bildirimler" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border x:Name="BildirimBadge" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="#E74C3C" WidthRequest="16" HeightRequest="16"
                            HorizontalOptions="End" VerticalOptions="Start" Margin="0,-6,-6,0"
                            IsVisible="False">
                        <Label x:Name="BildirimSayiLabel" Text="" FontSize="8" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Grid>
        </VerticalStackLayout>

        <CollectionView x:Name="ClassCollection" Grid.Row="2" Margin="15,0" SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="White" Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClassFrameTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="8, *, Auto">
                            <BoxView Grid.Column="0" BackgroundColor="#1ABC9C" WidthRequest="8" HorizontalOptions="Start"/>
                            <HorizontalStackLayout Grid.Column="1" Spacing="15" Padding="15,12">
                                <Image Source="classroom.png" WidthRequest="30" HeightRequest="30" VerticalOptions="Center" />
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding Ad}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="#2C3E50" />
                                    <Label Text="{Binding OgrenciSayisi, StringFormat='Sınıf Mevcudu: {0}'}" FontSize="11" TextColor="#1ABC9C" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <Label Grid.Column="2" Text="→" FontSize="24" TextColor="#1ABC9C" VerticalOptions="Center" Margin="0,0,15,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>