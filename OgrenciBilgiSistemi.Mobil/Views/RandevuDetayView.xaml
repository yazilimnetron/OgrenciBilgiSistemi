<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.RandevuDetayView"
             Title="Randevu Detayı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#2980B9">
            <Border.Shadow>
                <Shadow Brush="#2980B9" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" Margin="20,0,20,35">
                    <Label Text="Randevu Detayı" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,15,20,40" Spacing="15">

                <!-- Durum kartı -->
                <Border x:Name="DurumBorder" StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label x:Name="DurumIkon" FontSize="28" VerticalOptions="Center" />
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="DurumLabel" FontSize="18" FontFamily="OpenSansSemibold" />
                            <Label x:Name="DurumAciklama" FontSize="12" TextColor="#95A5A6" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Tarih ve süre -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <Grid ColumnDefinitions="*, *">
                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                            <Label Text="Tarih / Saat" FontSize="12" TextColor="#95A5A6" HorizontalOptions="Center" />
                            <Label x:Name="TarihLabel" FontSize="16" FontAttributes="Bold" TextColor="#2980B9" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="#ECF0F1" HorizontalOptions="End" Margin="0,5" />
                        <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                            <Label Text="Süre" FontSize="12" TextColor="#95A5A6" HorizontalOptions="Center" />
                            <Label x:Name="SureLabel" FontSize="16" FontAttributes="Bold" TextColor="#34495E" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Kişi bilgileri -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Katılımcılar" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" CharacterSpacing="1" />
                        <BoxView HeightRequest="1" Color="#F5F6FA" />
                        <Grid ColumnDefinitions="90, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="10" ColumnSpacing="10">
                            <Label Grid.Row="0" Grid.Column="0" Text="Öğretmen:" FontSize="14" TextColor="#95A5A6" VerticalOptions="Center" />
                            <Label Grid.Row="0" Grid.Column="1" x:Name="OgretmenLabel" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Veli:" FontSize="14" TextColor="#95A5A6" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="1" x:Name="VeliLabel" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />
                            <Label Grid.Row="2" Grid.Column="0" x:Name="OgrenciSatirLabel" Text="Öğrenci:" FontSize="14" TextColor="#95A5A6" VerticalOptions="Center" IsVisible="False" />
                            <Label Grid.Row="2" Grid.Column="1" x:Name="OgrenciLabel" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" IsVisible="False" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Not -->
                <Border x:Name="NotBorder" StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20" IsVisible="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Not" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <Label x:Name="NotLabel" FontSize="14" TextColor="#2C3E50" />
                    </VerticalStackLayout>
                </Border>

                <!-- Aksiyon butonları -->
                <VerticalStackLayout x:Name="AksiyonPanel" Spacing="10" IsVisible="False">
                    <Button x:Name="OnaylaButton" Text="Onayla" BackgroundColor="#27AE60" TextColor="White"
                            FontFamily="OpenSansSemibold" CornerRadius="12" HeightRequest="48"
                            Clicked="OnOnaylaClicked" IsVisible="False" />
                    <Button x:Name="ReddetButton" Text="Reddet" BackgroundColor="#E74C3C" TextColor="White"
                            FontFamily="OpenSansSemibold" CornerRadius="12" HeightRequest="48"
                            Clicked="OnReddetClicked" IsVisible="False" />
                    <Button x:Name="IptalButton" Text="İptal Et" BackgroundColor="#95A5A6" TextColor="White"
                            FontFamily="OpenSansSemibold" CornerRadius="12" HeightRequest="48"
                            Clicked="OnIptalClicked" IsVisible="False" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
