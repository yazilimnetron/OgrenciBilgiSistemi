<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.RandevuListeView"
             Title="Randevularım"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#2980B9" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="#2980B9" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" Margin="20,0,20,35">
                    <Label Text="Randevularım" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" />
                    <Label x:Name="AltBaslikLabel" Text="Tüm randevularınız" FontSize="14" TextColor="White" Opacity="0.8" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Yeni randevu ve bildirim butonları -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="15,-28,15,10" HeightRequest="55">
            <Button Grid.Column="0" Text="+ Yeni Randevu" BackgroundColor="#27AE60" TextColor="White"
                    FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="28" Margin="0,0,5,0"
                    Clicked="OnYeniRandevuClicked" />
            <Button Grid.Column="1" Text="Bildirimler" BackgroundColor="White" TextColor="#2980B9"
                    FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="28" Margin="5,0,0,0"
                    Clicked="OnBildirimlerClicked">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
                </Button.Shadow>
            </Button>
        </Grid>

        <RefreshView Grid.Row="2" x:Name="RandevuRefresh" Refreshing="OnRefreshing">
            <CollectionView x:Name="RandevuCollection" Margin="15,0" SelectionMode="None"
                              RemainingItemsThreshold="5"
                              RemainingItemsThresholdReached="OnRemainingItemsThresholdReached">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRandevuTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="8, *, Auto" Padding="0,15">
                                <BoxView Grid.Column="0" BackgroundColor="{Binding DurumRenk}" WidthRequest="8" HorizontalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="12,0">
                                    <Label Text="{Binding KarsiTarafAdi}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="#2C3E50" />
                                    <Label Text="{Binding OgrenciAdSoyad}" FontSize="12" TextColor="#7F8C8D" IsVisible="{Binding OgrenciGosterilsinMi}" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding TarihMetni}" FontSize="12" TextColor="#2980B9" />
                                        <Label Text="{Binding SureMetni}" FontSize="12" TextColor="#95A5A6" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                        BackgroundColor="{Binding DurumArkaplanRenk}" Padding="10,5" Margin="0,0,12,0"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding DurumAdi}" FontSize="11" TextColor="{Binding DurumRenk}" FontFamily="OpenSansSemibold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                        <Label Text="Henüz randevunuz bulunmuyor." FontSize="16" TextColor="#95A5A6" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
