@model SayfalanmisListeModel<OgrenciBilgiSistemi.Models.RandevuModel>
@using OgrenciBilgiSistemi.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Randevu Listesi";
    var arama = ViewData["Arama"] as string;
    var ogretmenId = ViewData["OgretmenId"] as int?;
    var durum = ViewData["Durum"] as RandevuDurumu?;
    var baslangic = ViewData["Baslangic"] as string;
    var bitis = ViewData["Bitis"] as string;
    var ogretmenler = ViewData["Ogretmenler"] as List<SelectListItem> ?? new();
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex gap-2 justify-content-between align-items-center mb-3 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-action="ExcelExport"
                   asp-route-arama="@arama"
                   asp-route-ogretmenId="@ogretmenId"
                   asp-route-durum="@((int?)durum)"
                   asp-route-baslangic="@baslangic"
                   asp-route-bitis="@bitis">
                    <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                </a>
            </div>

            @if (TempData["Hata"] is string hata)
            {
                <div class="alert alert-danger">@hata</div>
            }

            <!-- Filtreler -->
            <form method="get" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <!-- Arama -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input name="arama" value="@arama"
                           class="form-control" placeholder="Ad, soyad ara…" style="width:200px;" />
                </div>

                <!-- Öğretmen -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                    <select name="ogretmenId" class="form-select">
                        <option value="">Öğretmen</option>
                        @foreach (var o in ogretmenler)
                        {
                            <option value="@o.Value" selected="@(ogretmenId?.ToString() == o.Value)">@o.Text</option>
                        }
                    </select>
                </div>

                <!-- Durum -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-funnel"></i></span>
                    <select name="durum" class="form-select">
                        <option value="">Durum</option>
                        @foreach (RandevuDurumu d in Enum.GetValues<RandevuDurumu>())
                        {
                            <option value="@((int)d)" selected="@(durum == d)">@d</option>
                        }
                    </select>
                </div>

                <!-- Tarihler -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                    <input name="baslangic" type="date" value="@baslangic" class="form-control" />
                </div>

                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                    <input name="bitis" type="date" value="@bitis" class="form-control" />
                </div>

                <button class="btn btn-primary ms-auto px-3 text-nowrap" type="submit">
                    <i class="bi bi-search me-1"></i> Ara
                </button>
            </form>

            <!-- Liste -->
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Tarih</th>
                                <th>Öğretmen</th>
                                <th>Veli</th>
                                <th>Öğrenci</th>
                                <th>Durum</th>
                                <th>Oluşturan</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                <tr class="text-center">
                                    <td class="text-start fw-semibold text-primary">@r.RandevuTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@r.Ogretmen?.KullaniciAdi</td>
                                    <td>@r.Veli?.KullaniciAdi</td>
                                    <td>@(r.Ogrenci?.OgrenciAdSoyad ?? "-")</td>
                                    <td>
                                        @switch (r.Durum)
                                        {
                                            case RandevuDurumu.Beklemede:
                                                <span class="badge bg-warning text-dark">Beklemede</span>
                                                break;
                                            case RandevuDurumu.Onaylandi:
                                                <span class="badge bg-success">Onaylandı</span>
                                                break;
                                            case RandevuDurumu.Reddedildi:
                                                <span class="badge bg-danger">Reddedildi</span>
                                                break;
                                            case RandevuDurumu.IptalEdildi:
                                                <span class="badge bg-secondary">İptal</span>
                                                break;
                                            case RandevuDurumu.Tamamlandi:
                                                <span class="badge bg-info">Tamamlandı</span>
                                                break;
                                        }
                                    </td>
                                    <td>@(r.OgretmenTarafindanOlusturuldu ? "Öğretmen" : "Veli")</td>
                                    <td>
                                        <div class="btn-group btn-group-gap" role="group">
                                            <a asp-action="Detay" asp-route-id="@r.RandevuId"
                                               class="btn btn-outline-secondary btn-sm">
                                                <i class="bi bi-eye"></i> Detay
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @await Html.PartialAsync("_SayfalamaFormPartial", OgrenciBilgiSistemi.ViewModels.SayfalamaVm.Olustur(Model,
                    sayfaParametreAdi: "sayfaNo",
                    routeValues: new Dictionary<string, string?>
                    {
                        ["arama"] = arama,
                        ["ogretmenId"] = ogretmenId?.ToString(),
                        ["durum"] = ((int?)durum)?.ToString(),
                        ["baslangic"] = baslangic,
                        ["bitis"] = bitis
                    }))
            }
        </div>
    </div>
</div>
