@model OgrenciBilgiSistemi.ViewModels.OgrenciDetayRaporVm
@using System.Globalization
@using System.Linq
@using OgrenciBilgiSistemi.Models

@{
    ViewData["Title"] = "Öğrenci Giriş-Çıkış Detayı";
    var culture = CultureInfo.CurrentCulture;

    var currentSort = ViewData["CurrentSort"] as string;
    var currentFilter = ViewData["CurrentFilter"] as string;
    var startDate = ViewData["StartDate"] as string;
    var endDate = ViewData["EndDate"] as string;
    var vRapor = ViewData["RaporTipi"]?.ToString() ?? "0";
    var rt = Model?.RaporTipi ?? RaporTipi.Tumu;
    bool gosterGecis = rt == RaporTipi.Tumu || rt == RaporTipi.AnaKapiGecisleri || rt == RaporTipi.YemekhaneGecisleri;
    bool gosterSinif = rt == RaporTipi.SinifYoklamasi;
    bool gosterServis = rt == RaporTipi.ServisYoklamasi;

    string SortClass(string col)
    {
        if (string.IsNullOrEmpty(currentSort) && col == "Tarih_desc")
            return "text-decoration-underline";
        return currentSort == col ? "text-decoration-underline" : "";
    }

    string NextSort(string col) => currentSort == col ? col + "_desc" : col;

    string SinifDurumMetni(int? d) => d switch
    {
        1 => "Geldi",
        2 => "Gelmedi",
        3 => "Geç Geldi",
        4 => "İzinli",
        5 => "Raporlu",
        6 => "Nöbetçi",
        7 => "Görevli",
        null => "-",
        _ => d.ToString()!
    };

    string SinifDurumBadge(int? d) => d switch
    {
        1 => "bg-success",
        2 => "bg-danger",
        3 => "bg-warning text-dark",
        4 => "bg-primary",
        5 => "bg-purple",
        6 => "bg-dark",
        7 => "bg-secondary",
        _ => "bg-light text-dark"
    };
}

<div class="viewport-scroller">
    <div class="fixed-canvas">

        <div class="card border rounded-4 p-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex gap-2 justify-content-between align-items-center mb-3 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>

                <a class="btn btn-success fw-semibold"
                   asp-action="DetayExcel"
                   asp-route-sortOrder="@currentSort"
                   asp-route-searchString="@currentFilter"
                   asp-route-startDate="@startDate"
                   asp-route-endDate="@endDate"
                   asp-route-raporTipi="@vRapor">
                    <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                </a>
            </div>

            <form id="raporFilterForm" method="get"
                  asp-action="Detay"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <input type="hidden" name="page" value="1" />

                <!-- Arama -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input name="searchString" value="@currentFilter"
                           class="form-control" placeholder="Ad/soyad, numara veya kart no…" style="width:260px;" />
                </div>

                <!-- Tarihler -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                    <input name="startDate" type="date" value="@startDate" class="form-control" />
                </div>

                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-calendar-event"></i></span>
                    <input name="endDate" type="date" value="@endDate" class="form-control" />
                </div>

                <!-- Rapor Tipi -->
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-funnel"></i></span>
                    <select name="raporTipi" class="form-select" onchange="this.form.submit()">
                        @foreach (var item in Html.GetEnumSelectList<RaporTipi>())
                        {
                            if (vRapor == item.Value)
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                <button class="btn btn-primary ms-auto px-3 text-nowrap" type="submit">
                    <i class="bi bi-search me-1"></i> Ara
                </button>
            </form>

            <!-- Liste -->
            @{
                bool bos = (gosterGecis && (Model.Gecisler == null || !Model.Gecisler.Any()))
                        || (gosterSinif && (Model.SinifYoklamalar == null || !Model.SinifYoklamalar.Any()))
                        || (gosterServis && (Model.ServisYoklamalar == null || !Model.ServisYoklamalar.Any()));
            }
            @if (bos)
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                @if (gosterGecis)
                {
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Adı Soyadı</th>
                                <th>Sınıfı</th>
                                <th>No</th>
                                <th>Kart No</th>
                                <th>Giriş</th>
                                <th>Çıkış</th>
                                <th>Tip</th>
                                <th>Cihaz</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model.Gecisler!)
                            {
                                <tr class="text-center">
                                    <td class="text-start">@x.Ogrenci?.OgrenciAdSoyad</td>
                                    <td>@x.Ogrenci?.Birim?.BirimAd</td>
                                    <td>@x.Ogrenci?.OgrenciNo</td>
                                    <td>@x.Ogrenci?.OgrenciKartNo</td>
                                    <td>@(x.OgrenciGTarih?.ToString("g", culture))</td>
                                    <td>@(x.OgrenciCTarih?.ToString("g", culture))</td>
                                    <td>@x.IstasyonTipi</td>
                                    <td>@x.Cihaz?.CihazAdi</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (gosterSinif)
                {
                    <table class="table table-hover table-sm align-middle text-center">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="text-start">Adı Soyadı</th>
                                <th>Sınıfı</th>
                                <th>Tarih</th>
                                <th>D1</th><th>D2</th><th>D3</th><th>D4</th>
                                <th>D5</th><th>D6</th><th>D7</th><th>D8</th>
                                <th>Kaydeden</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sy in Model.SinifYoklamalar!)
                            {
                                <tr>
                                    <td class="text-start">@sy.Ogrenci?.OgrenciAdSoyad</td>
                                    <td>@sy.Ogrenci?.Birim?.BirimAd</td>
                                    <td>@sy.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@if (sy.Ders1.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders1)">@SinifDurumMetni(sy.Ders1)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders2.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders2)">@SinifDurumMetni(sy.Ders2)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders3.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders3)">@SinifDurumMetni(sy.Ders3)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders4.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders4)">@SinifDurumMetni(sy.Ders4)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders5.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders5)">@SinifDurumMetni(sy.Ders5)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders6.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders6)">@SinifDurumMetni(sy.Ders6)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders7.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders7)">@SinifDurumMetni(sy.Ders7)</span>} else {<text>-</text>}</td>
                                    <td>@if (sy.Ders8.HasValue) {<span class="badge @SinifDurumBadge(sy.Ders8)">@SinifDurumMetni(sy.Ders8)</span>} else {<text>-</text>}</td>
                                    <td>@(sy.Kullanici?.KullaniciAdi ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (gosterServis)
                {
                    <table class="table table-hover table-sm align-middle text-center">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="text-start">Adı Soyadı</th>
                                <th>Sınıfı</th>
                                <th>Tarih</th>
                                <th>Periyot</th>
                                <th>Durum</th>
                                <th>SMS</th>
                                <th>Şoför</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sv in Model.ServisYoklamalar!)
                            {
                                <tr>
                                    <td class="text-start">@sv.Ogrenci?.OgrenciAdSoyad</td>
                                    <td>@sv.Ogrenci?.Birim?.BirimAd</td>
                                    <td>@sv.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@(sv.Periyot == 1 ? "Sabah" : (sv.Periyot == 2 ? "Akşam" : sv.Periyot.ToString()))</td>
                                    <td>
                                        @if (sv.DurumId == 1)
                                        {
                                            <span class="badge bg-success">Bindi</span>
                                        }
                                        else if (sv.DurumId == 2)
                                        {
                                            <span class="badge bg-danger">Binmedi</span>
                                        }
                                        else
                                        {
                                            @sv.DurumId
                                        }
                                    </td>
                                    <td>@(sv.SmsGonderildi ? "Evet" : "Hayır")</td>
                                    <td>@(sv.Kullanici?.KullaniciAdi ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                </div>

                <!-- Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@Model.ToplamSayi</strong> kayıt • Sayfa <strong>@Model.SayfaIndeks</strong>/<strong>@Model.ToplamSayfa</strong>
                    </div>

                    <div class="btn-group">
                        <a class="btn btn-outline-secondary @(Model.OncekiSayfaVar ? "" : "disabled")"
                           asp-action="Detay"
                           asp-route-page="@(Model.SayfaIndeks - 1)"
                           asp-route-sortOrder="@currentSort"
                           asp-route-searchString="@currentFilter"
                           asp-route-startDate="@startDate"
                           asp-route-endDate="@endDate"
                           asp-route-raporTipi="@vRapor">
                            ‹ Önceki
                        </a>

                        <a class="btn btn-outline-secondary @(Model.SonrakiSayfaVar ? "" : "disabled")"
                           asp-action="Detay"
                           asp-route-page="@(Model.SayfaIndeks + 1)"
                           asp-route-sortOrder="@currentSort"
                           asp-route-searchString="@currentFilter"
                           asp-route-startDate="@startDate"
                           asp-route-endDate="@endDate"
                           asp-route-raporTipi="@vRapor">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }

        </div>

    </div>
</div>