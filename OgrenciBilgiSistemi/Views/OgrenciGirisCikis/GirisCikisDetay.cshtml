@model OgrenciBilgiSistemi.ViewModels.OgrenciGirisCikisListViewModel

@{
    ViewData["Title"] = "Öğrenci Giriş-Çıkış Listesi";
    var currentYear = DateTime.Now.Year;

    // ViewData -> güvenli parse
    DateTime? vStart = null, vEnd = null;
    if (ViewData["StartDate"] is DateTime d1) vStart = d1;
    else if (ViewData["StartDate"] is string s1 && DateTime.TryParse(s1, out var p1)) vStart = p1;

    if (ViewData["EndDate"] is DateTime d2) vEnd = d2;
    else if (ViewData["EndDate"] is string s2 && DateTime.TryParse(s2, out var p2)) vEnd = p2;

    var vRapor = ViewData["RaporTipi"]?.ToString() ?? "0";
    var rt = Model.RaporTipi;
    bool gosterGecis = rt == RaporTipi.Tumu || rt == RaporTipi.AnaKapiGecisleri || rt == RaporTipi.YemekhaneGecisleri;
    bool gosterSinif = rt == RaporTipi.Tumu || rt == RaporTipi.SinifYoklamasi;
    bool gosterServis = rt == RaporTipi.Tumu || rt == RaporTipi.ServisYoklamasi;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <!-- Üst Sekmeler + Yıl Seçimi -->
        <ul class="nav nav-tabs mb-2 align-items-center">
            <li class="nav-item">
                <a class="nav-link active">Giriş/Çıkış</a>
            </li>
            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Aidat"
                   asp-action="Ozet"
                   asp-route-ogrenciId="@Model.Ogrenci.OgrenciId"
                   asp-route-yil="@currentYear">
                    Aidat
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link"
                   asp-controller="Yemekhane"
                   asp-action="Ozet"
                   asp-route-ogrenciId="@Model.Ogrenci.OgrenciId">Yemekhane</a>
            </li>

            <li class="ms-auto">
                <form method="get" asp-controller="Aidat" asp-action="Ozet" class="d-flex gap-2">
                    <input type="hidden" name="ogrenciId" value="@Model.Ogrenci.OgrenciId" />
                </form>
            </li>
        </ul>

        <div class="card rounded-4">
            <!-- Başlık -->
            <div class="card-header rounded-top-4 d-flex flex-row justify-content-between align-items-center gap-2">
                <h5 class="mb-0 text-primary fw-bold">
                    @Model.Ogrenci.OgrenciAdSoyad — Giriş/Çıkış
                </h5>
                <div class="d-flex gap-2">
                    <a asp-action="DetayExportToExcel"
                       asp-route-id="@Model.Ogrenci.OgrenciId"
                       asp-route-searchName="@ViewData["SearchName"]"
                       asp-route-startDate="@(vStart?.ToString("yyyy-MM-dd"))"
                       asp-route-endDate="@(vEnd?.ToString("yyyy-MM-dd"))"
                       asp-route-raporTipi="@vRapor"
                       class="btn btn-outline-success btn-sm fw-bold">
                        <i class="bi bi-file-earmark-excel"></i> Excel'e Aktar
                    </a>
                    <a asp-controller="Ogrenciler" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Listeye Dön
                    </a>
                </div>
            </div>

            <div class="card-body p-4">
                <!-- Arama & Filtreleme -->
                <form method="get" asp-action="GirisCikisDetay" class="row g-2 mb-3">
                    <input type="hidden" name="id" value="@Model.Ogrenci.OgrenciId" />

                    <div class="col-3">
                        <input type="date" name="startDate" class="form-control" value="@(vStart?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-3">
                        <input type="date" name="endDate" class="form-control" value="@(vEnd?.ToString("yyyy-MM-dd"))" />
                    </div>

                    <!-- RAPOR TİPİ FİLTRESİ -->
                    <div class="col-3">
                        @{
                            var raporItems = Html.GetEnumSelectList<RaporTipi>();
                        }
                        <select name="raporTipi" class="form-select">
                            @foreach (var item in raporItems)
                            {
                                if (vRapor == item.Value)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Ara
                        </button>
                    </div>
                </form>

@if (gosterGecis)
{
<!-- Öğrenci Hareketleri Tablosu -->
                <div class="table-scroll">
                    <table class="table table-hover table-sm text-center align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th>Giriş Tarihi</th>
                                <th>Çıkış Tarihi</th>
                                <th>Geçiş Tipi</th>
                                <th>Cihaz Adı</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @if (!Model.Hareketler.Any())
                            {
                                <tr>
                                    <td colspan="5" class="p-4">
                                        <div class="alert alert-warning text-center m-0">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Henüz kayıtlı hareket bulunmamaktadır.
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var log in Model.Hareketler)
                                {
                                    <tr>
                                        <td>@log.OgrenciDetayId</td>
                                        <td>@(log.OgrenciGTarih?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                        <td>@(log.OgrenciCTarih?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                        <td>@log.OgrenciGecisTipi</td>
                                        <td>@log.CihazAdi</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
}

@if (gosterSinif)
{
                <!-- Sınıf Yoklamaları -->
                <h6 class="mt-4 mb-2 fw-bold text-primary">
                    <i class="bi bi-journal-check"></i> Sınıf Yoklamaları
                </h6>
                <div class="table-scroll">
                    <table class="table table-hover table-sm text-center align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th>Tarih</th>
                                <th>Ders 1</th>
                                <th>Ders 2</th>
                                <th>Ders 3</th>
                                <th>Ders 4</th>
                                <th>Ders 5</th>
                                <th>Ders 6</th>
                                <th>Ders 7</th>
                                <th>Ders 8</th>
                                <th>Kaydeden</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @if (Model.SinifYoklamalar == null || !Model.SinifYoklamalar.Any())
                            {
                                <tr>
                                    <td colspan="11" class="p-3">
                                        <div class="alert alert-warning text-center m-0">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Sınıf yoklaması kaydı bulunmamaktadır.
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var sy in Model.SinifYoklamalar)
                                {
                                    <tr>
                                        <td>@sy.SinifYoklamaId</td>
                                        <td>@sy.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        @{
                                            int?[] dersler = new int?[] { sy.Ders1, sy.Ders2, sy.Ders3, sy.Ders4, sy.Ders5, sy.Ders6, sy.Ders7, sy.Ders8 };
                                        }
                                        @for (int i = 0; i < 8; i++)
                                        {
                                            var d = dersler[i];
                                            var smsBit = (sy.SmsDurumu & (1 << i)) != 0;
                                            <td>
                                                @(d?.ToString() ?? "-")
                                                @if (smsBit)
                                                {
                                                    <span class="badge bg-info ms-1" title="SMS gönderildi">SMS</span>
                                                }
                                            </td>
                                        }
                                        <td>@(sy.Kullanici?.KullaniciAdi ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

}

@if (gosterServis)
{
                <!-- Servis Yoklamaları -->
                <h6 class="mt-4 mb-2 fw-bold text-primary">
                    <i class="bi bi-bus-front"></i> Servis Yoklamaları
                </h6>
                <div class="table-scroll">
                    <table class="table table-hover table-sm text-center align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th>Tarih</th>
                                <th>Periyot</th>
                                <th>Durum</th>
                                <th>SMS</th>
                                <th>Şoför</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @if (Model.ServisYoklamalar == null || !Model.ServisYoklamalar.Any())
                            {
                                <tr>
                                    <td colspan="6" class="p-3">
                                        <div class="alert alert-warning text-center m-0">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Servis yoklaması kaydı bulunmamaktadır.
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var sv in Model.ServisYoklamalar)
                                {
                                    <tr>
                                        <td>@sv.ServisYoklamaId</td>
                                        <td>@sv.OlusturulmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@(sv.Periyot == 1 ? "Sabah" : (sv.Periyot == 2 ? "Akşam" : sv.Periyot.ToString()))</td>
                                        <td>
                                            @if (sv.DurumId == 1)
                                            {
                                                <span class="badge bg-success">Bindi</span>
                                            }
                                            else if (sv.DurumId == 2)
                                            {
                                                <span class="badge bg-danger">Binmedi</span>
                                            }
                                            else
                                            {
                                                @sv.DurumId
                                            }
                                        </td>
                                        <td>
                                            @if (sv.SmsGonderildi)
                                            {
                                                <span class="badge bg-info">Evet</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Hayır</span>
                                            }
                                        </td>
                                        <td>@(sv.Kullanici?.KullaniciAdi ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
}
            </div>
        </div>

        <!-- Toplam Kayıt -->
        <div class="mt-3 text-end">
            <span class="fw-bold text-muted">
                Toplam <span class="text-primary">@Model.Hareketler.Count()</span> kayıt listelenmiştir.
            </span>
        </div>

        <!-- Sayfalama -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @if (Model.Hareketler.OncekiSayfaVar)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="GirisCikisDetay"
                           asp-route-id="@Model.Ogrenci.OgrenciId"
                           asp-route-pageNumber="@(Model.Hareketler.SayfaIndeks - 1)"
                           asp-route-searchName="@ViewData["SearchName"]"
                           asp-route-startDate="@(vStart?.ToString("yyyy-MM-dd"))"
                           asp-route-endDate="@(vEnd?.ToString("yyyy-MM-dd"))"
                           asp-route-raporTipi="@vRapor">Önceki</a>
                    </li>
                }

                @if (Model.Hareketler.SayfaIndeks > 3)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="GirisCikisDetay" asp-route-pageNumber="1"
                           asp-route-id="@Model.Ogrenci.OgrenciId"
                           asp-route-searchName="@ViewData["SearchName"]"
                           asp-route-startDate="@(vStart?.ToString("yyyy-MM-dd"))"
                           asp-route-endDate="@(vEnd?.ToString("yyyy-MM-dd"))"
                           asp-route-raporTipi="@vRapor">1</a>
                    </li>
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }

                @for (int i = Math.Max(1, Model.Hareketler.SayfaIndeks - 2); i <= Math.Min(Model.Hareketler.ToplamSayfa, Model.Hareketler.SayfaIndeks + 2); i++)
                {
                    <li class="page-item @(i == Model.Hareketler.SayfaIndeks ? "active" : "")">
                        <a class="page-link" asp-action="GirisCikisDetay" asp-route-pageNumber="@i"
                           asp-route-id="@Model.Ogrenci.OgrenciId"
                           asp-route-searchName="@ViewData["SearchName"]"
                           asp-route-startDate="@(vStart?.ToString("yyyy-MM-dd"))"
                           asp-route-endDate="@(vEnd?.ToString("yyyy-MM-dd"))"
                           asp-route-raporTipi="@vRapor">@i</a>
                    </li>
                }

                @if (Model.Hareketler.SayfaIndeks < Model.Hareketler.ToplamSayfa - 2)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                    <li class="page-item">
                        <a class="page-link" asp-action="GirisCikisDetay" asp-route-pageNumber="@Model.Hareketler.ToplamSayfa"
                           asp-route-id="@Model.Ogrenci.OgrenciId"
                           asp-route-searchName="@ViewData["SearchName"]"
                           asp-route-startDate="@(vStart?.ToString("yyyy-MM-dd"))"
                           asp-route-endDate="@(vEnd?.ToString("yyyy-MM-dd"))"
                           asp-route-raporTipi="@vRapor">@Model.Hareketler.ToplamSayfa</a>
                    </li>
                }

                @if (Model.Hareketler.SonrakiSayfaVar)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="GirisCikisDetay"
                           asp-route-id="@Model.Ogrenci.OgrenciId"
                           asp-route-pageNumber="@(Model.Hareketler.SayfaIndeks + 1)"
                           asp-route-searchName="@ViewData["SearchName"]"
                           asp-route-startDate="@(vStart?.ToString("yyyy-MM-dd"))"
                           asp-route-endDate="@(vEnd?.ToString("yyyy-MM-dd"))"
                           asp-route-raporTipi="@vRapor">Sonraki</a>
                    </li>
                }
            </ul>
        </nav>

    </div>
</div>