<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0" />
    <meta name="description" content="Öğrenci Bilgi Sistemi - Öğrenci ve Kitap Yönetimi" />
    <meta name="keywords" content="Öğrenci, Kitap, Yönetim, Bilgi Sistemi" />
    <title>@ViewData["Title"] - Öğrenci Bilgi Sistemi</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OgrenciBilgiSistemi.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var isHomeIndex =
        (ViewContext.RouteData.Values["controller"]?.ToString() == "Home") &&
        (ViewContext.RouteData.Values["action"]?.ToString() == "Index");

        var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
        var isAdmin = isAuthenticated && (User.IsInRole("Admin") || User.IsInRole("GenelAdmin"));
        var isGenelAdmin = isAuthenticated && User.IsInRole("GenelAdmin");
        var okulAdi = User.FindFirst("okulAdi")?.Value ?? Context.Session.GetString("SeciliOkulKodu") ?? "";
    }

    @if (isAuthenticated)
    {
        <header>
            <nav class="navbar navbar-expand bg-body-tertiary border-bottom">
                <div class="container-fluid">
                    <ul class="navbar-nav me-auto mb-0">
                        @await Component.InvokeAsync("Menu")
                    </ul>

                    <ul class="navbar-nav ms-auto mb-0 align-items-center">
                        @if (!string.IsNullOrEmpty(okulAdi))
                        {
                            <li class="nav-item">
                                <span class="nav-link text-muted">
                                    <i class="bi bi-building"></i> @okulAdi
                                </span>
                            </li>
                        }
                        @if (isGenelAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="OkulSecim" asp-action="Index">
                                    <i class="bi bi-arrow-left-right"></i> Okul Değiştir
                                </a>
                            </li>
                        }
                        <li class="nav-item d-flex align-items-center">
                            <form asp-controller="Hesaplar" asp-action="Cikis" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link">
                                    <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>
    }
    else
    {
        <header>
            <nav class="navbar navbar-expand bg-body-tertiary border-bottom">
                <div class="container-fluid"></div>
            </nav>
        </header>
    }

    <partial name="~/Views/Shared/_StatusAlert.cshtml" />

    @* 🔹 Home/Index için özel davranış *@
    @if (isHomeIndex)
    {
        if (!isAdmin)
        {
            <!-- ANONİM veya ADMIN OLMAYAN KULLANICI: LOGO (HERO) -->
            <section class="d-flex flex-column justify-content-center align-items-center text-center" style="min-height:70vh;">
                <img src="~/images/ilcelogo.png" alt="Okul Logosu" width="280" height="280" class="mb-4" />
                <div>
                    <h2 class="fw-normal text-primary mb-1" style="font-size:1.6rem; letter-spacing:0.5px;">
                        Öğrenci Bilgi Sistemi
                    </h2>
                </div>
            </section>
        }
        else
        {
            @RenderBody()
        }
    }
    else
    {
        @RenderBody()
    }

    <!-- jQuery (yerel) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Validation (jQuery'den sonra) -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <!-- Bootstrap (yerel) -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Proje script'i -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>