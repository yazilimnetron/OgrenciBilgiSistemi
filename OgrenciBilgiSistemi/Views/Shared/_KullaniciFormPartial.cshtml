@model OgrenciBilgiSistemi.Models.KullaniciModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var action = (ViewData["Action"] as string) ?? "Ekle";      // "Ekle" | "Guncelle"
    var submitText = (ViewData["SubmitText"] as string) ?? "Kaydet";    // "Kaydet" | "Güncelle"
    var includeId = (bool?)ViewData["IncludeId"] ?? false;       // Güncelle'de true

    var formId = "kullaniciForm";
    var submitBtnId = "submitBtn";

    var veliler = Model?.Veliler ?? new List<SelectListItem>();
    var personeller = Model?.Personeller ?? new List<SelectListItem>();
    var servisler = Model?.Servisler ?? new List<SelectListItem>();

    // KullaniciRolu enum değerleri
    var ogretmenRolDegeri = (int)OgrenciBilgiSistemi.Shared.Enums.KullaniciRolu.Ogretmen;
    var soforRolDegeri = (int)OgrenciBilgiSistemi.Shared.Enums.KullaniciRolu.Sofor;
    var veliRolDegeri = (int)OgrenciBilgiSistemi.Shared.Enums.KullaniciRolu.Veli;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-xxl-5">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(action == "Ekle" ? "Kullanıcı Ekle" : "Kullanıcı Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" id="@formId" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (includeId)
                                {
                                    <input type="hidden" asp-for="KullaniciId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <!-- Kullanıcı Adı -->
                                <div class="mb-3">
                                    <label asp-for="KullaniciAdi" class="form-label fw-semibold">Kullanıcı Adı</label>
                                    <input asp-for="KullaniciAdi"
                                           class="form-control"
                                           required minlength="3"
                                           placeholder="Kullanıcı adı giriniz" />
                                    <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                                </div>

                                <!-- Şifre -->
                                <div class="mb-3">
                                    <label asp-for="Sifre" class="form-label fw-semibold">Şifre</label>
                                    <input asp-for="Sifre"
                                           class="form-control"
                                           type="password"
                                           required minlength="3"
                                           placeholder="Şifre giriniz" />
                                    <span asp-validation-for="Sifre" class="text-danger"></span>
                                </div>

                                <!-- Kullanıcı Durumu -->
                                <div class="mb-3">
                                    <label asp-for="KullaniciDurum" class="form-label fw-semibold">Kullanıcı Durumu</label>
                                    <select asp-for="KullaniciDurum" class="form-select">
                                        <option value="true">Aktif</option>
                                        <option value="false">Pasif</option>
                                    </select>
                                    <span asp-validation-for="KullaniciDurum" class="text-danger"></span>
                                </div>

                                <!-- Rol -->
                                <div class="mb-3">
                                    <label asp-for="Rol" class="form-label fw-semibold">Rol</label>
                                    <select asp-for="Rol" class="form-select"
                                            asp-items="Html.GetEnumSelectList<OgrenciBilgiSistemi.Shared.Enums.KullaniciRolu>()">
                                    </select>
                                    <span asp-validation-for="Rol" class="text-danger"></span>
                                </div>

                                <!-- Telefon -->
                                <div class="mb-3">
                                    <label asp-for="Telefon" class="form-label fw-semibold">Telefon</label>
                                    <input asp-for="Telefon"
                                           class="form-control"
                                           placeholder="5XXXXXXXXX" />
                                    <span asp-validation-for="Telefon" class="text-danger"></span>
                                </div>

                                <!-- Personel Seçimi (Rol = Öğretmen olduğunda görünür) -->
                                <div class="mb-4" id="personelSecimAlani" style="display:none;">
                                    <label asp-for="PersonelId" class="form-label fw-semibold">Bağlı Personel</label>
                                    <select asp-for="PersonelId" class="form-select" asp-items="personeller">
                                        <option value="">-- Personel Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="PersonelId" class="text-danger"></span>
                                    <div class="form-text">Öğretmen rolündeki kullanıcının hangi personele bağlı olduğunu seçiniz.</div>
                                </div>

                                <!-- Servis Seçimi (Rol = Şoför olduğunda görünür) -->
                                <div class="mb-4" id="servisSecimAlani" style="display:none;">
                                    <label asp-for="ServisId" class="form-label fw-semibold">Bağlı Servis</label>
                                    <select asp-for="ServisId" class="form-select" asp-items="servisler">
                                        <option value="">-- Servis Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="ServisId" class="text-danger"></span>
                                    <div class="form-text">Şoför rolündeki kullanıcının hangi servise bağlı olduğunu seçiniz.</div>
                                </div>

                                <!-- Veli Seçimi (Rol = Veli olduğunda görünür) -->
                                <div class="mb-4" id="veliSecimAlani" style="display:none;">
                                    <label asp-for="OgrenciVeliId" class="form-label fw-semibold">Bağlı Veli</label>
                                    <select asp-for="OgrenciVeliId" class="form-select" asp-items="veliler">
                                        <option value="">-- Veli Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="OgrenciVeliId" class="text-danger"></span>
                                    <div class="form-text">Veli rolündeki kullanıcının hangi veliye bağlı olduğunu seçiniz.</div>
                                </div>

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri Dön
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold" id="@submitBtnId">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div> <!-- /card-body -->
                    </div> <!-- /card -->
                </div>
            </div>
        </div> <!-- /container -->
    </div>
</div>

@section Scripts {
    <script>
        // Rol değiştiğinde ilgili alanları göster/gizle
        (function () {
            const OGRETMEN_ROL = '@ogretmenRolDegeri';
            const SOFOR_ROL = '@soforRolDegeri';
            const VELI_ROL = '@veliRolDegeri';

            const rolSelect = document.getElementById('Rol');
            const personelAlani = document.getElementById('personelSecimAlani');
            const servisAlani = document.getElementById('servisSecimAlani');
            const veliAlani = document.getElementById('veliSecimAlani');

            function rolDegisti() {
                if (!rolSelect) return;
                const val = rolSelect.value;
                if (personelAlani) personelAlani.style.display = (val === OGRETMEN_ROL) ? '' : 'none';
                if (servisAlani) servisAlani.style.display = (val === SOFOR_ROL) ? '' : 'none';
                if (veliAlani) veliAlani.style.display = (val === VELI_ROL) ? '' : 'none';
            }

            if (rolSelect) {
                rolSelect.addEventListener('change', rolDegisti);
                rolDegisti(); // sayfa yüklendiğinde de kontrol et
            }
        })();

        // Double-submit koruması (spinner yok)
        (function () {
            const form = document.getElementById('@formId');
            const btn  = document.getElementById('@submitBtnId');
            if (!form || !btn) return;

            form.addEventListener('submit', function () {
                if (form.checkValidity()) {
                    btn.disabled = true;
                    btn.textContent = '@(submitText.EndsWith("e") ? submitText + "iliyor..." : submitText + "iyor...")';
                }
            });
        })();
    </script>
}
