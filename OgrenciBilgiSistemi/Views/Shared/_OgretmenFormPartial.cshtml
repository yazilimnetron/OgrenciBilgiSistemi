@model OgrenciBilgiSistemi.Models.OgretmenProfilModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var action = (ViewData["Action"] as string) ?? "Ekle";
    var submitText = (ViewData["SubmitText"] as string) ?? "Kaydet";
    var includeId = (bool?)ViewData["IncludeId"] ?? false;

    var kullanicilar = ViewBag.Kullanicilar as List<SelectListItem> ?? new List<SelectListItem>();
    var birimler = ViewBag.Birimler as List<SelectListItem> ?? new List<SelectListItem>();

    var formId = "ogretmenForm";
    var submitBtnId = "submitBtn";
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-5">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(action == "Ekle" ? "Öğretmen Ekle" : "Öğretmen Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" id="@formId" enctype="multipart/form-data" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (includeId)
                                {
                                    <input type="hidden" asp-for="KullaniciId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <!-- Kullanıcı -->
                                <div class="mb-3">
                                    <label asp-for="KullaniciId" class="form-label fw-semibold">Kullanıcı</label>
                                    @if (includeId)
                                    {
                                        <select asp-for="KullaniciId" class="form-select" asp-items="kullanicilar" disabled>
                                            <option value="">-- Kullanıcı Seçiniz --</option>
                                        </select>
                                        <input type="hidden" asp-for="KullaniciId" />
                                    }
                                    else
                                    {
                                        <select asp-for="KullaniciId" class="form-select" asp-items="kullanicilar">
                                            <option value="">-- Kullanıcı Seçiniz --</option>
                                        </select>
                                    }
                                    <span asp-validation-for="KullaniciId" class="text-danger"></span>
                                </div>

                                <!-- E-posta -->
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold">E-posta</label>
                                    <input asp-for="Email"
                                           class="form-control"
                                           placeholder="ornek@okul.edu.tr" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <!-- Birim -->
                                <div class="mb-3">
                                    <label asp-for="BirimId" class="form-label fw-semibold">Birim</label>
                                    <select asp-for="BirimId" class="form-select" asp-items="birimler">
                                        <option value="">-- Birim Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="BirimId" class="text-danger"></span>
                                </div>

                                <!-- Fotoğraf -->
                                <div class="mb-3">
                                    <label asp-for="GorselFile" class="form-label fw-semibold">Fotoğraf</label>
                                    @if (!string.IsNullOrEmpty(Model?.GorselPath))
                                    {
                                        <div class="mb-2">
                                            <img src="@Model.GorselPath" alt="Mevcut fotoğraf"
                                                 class="rounded" style="max-height:120px;" />
                                        </div>
                                    }
                                    <input asp-for="GorselFile" class="form-control" accept="image/*" />
                                    <span asp-validation-for="GorselFile" class="text-danger"></span>
                                </div>

                                <!-- Durum -->
                                <div class="mb-3">
                                    <label asp-for="OgretmenDurum" class="form-label fw-semibold">Durum</label>
                                    <select asp-for="OgretmenDurum" class="form-select">
                                        <option value="true">Aktif</option>
                                        <option value="false">Pasif</option>
                                    </select>
                                    <span asp-validation-for="OgretmenDurum" class="text-danger"></span>
                                </div>

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri Dön
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold" id="@submitBtnId">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

