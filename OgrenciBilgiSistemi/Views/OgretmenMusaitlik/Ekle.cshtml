@model OgrenciBilgiSistemi.Models.OgretmenMusaitlikModel
@using OgrenciBilgiSistemi.Shared.Enums
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Müsaitlik Ekle";
    var ogretmenler = ViewData["Ogretmenler"] as List<SelectListItem> ?? new();
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-6">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">@ViewData["Title"]</h4>
                        </div>
                        <div class="card-body p-4">
                            <form method="post" asp-action="Ekle" autocomplete="off">
                                @Html.AntiForgeryToken()
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="mb-3">
                                    <label asp-for="OgretmenKullaniciId" class="form-label fw-semibold">Öğretmen</label>
                                    <select asp-for="OgretmenKullaniciId" class="form-select" asp-items="ogretmenler">
                                        <option value="">-- Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="OgretmenKullaniciId" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Gun" class="form-label fw-semibold">Gün</label>
                                    <select asp-for="Gun" class="form-select" asp-items="Html.GetEnumSelectList<GunEnum>()">
                                    </select>
                                    <span asp-validation-for="Gun" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="BaslangicSaati" class="form-label fw-semibold">Başlangıç Saati</label>
                                    <input asp-for="BaslangicSaati" type="time" class="form-control" />
                                    <span asp-validation-for="BaslangicSaati" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="BitisSaati" class="form-label fw-semibold">Bitiş Saati</label>
                                    <input asp-for="BitisSaati" type="time" class="form-control" />
                                    <span asp-validation-for="BitisSaati" class="text-danger"></span>
                                </div>

                                <div class="d-flex justify-content-between mt-3">
                                    <a asp-action="Index" asp-route-ogretmenId="@Model.OgretmenKullaniciId" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri Dön
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold">
                                        <i class="bi bi-save"></i> Kaydet
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
